# Relay server configuration. Copy to .env and edit for local dev,
# or set these in your deployment environment (Vercel, Fly.io, your VPS).

# --- Network ---
PORT=4000
HOST=0.0.0.0

# Comma-separated origins allowed to hit the relay. "*" is fine for dev and
# for a public read-only relay; lock down to specific origins in production.
CORS_ORIGINS=*

# --- CV service ---
# Default points at larv.ai. Forkers running their own CV service can point
# here without any code changes.
CV_API_BASE_URL=https://larv.ai/api/cv

# Shared secret that authenticates /api/cv/spend calls. Required in Phase 1
# (when /chat and /engagement go live). Not needed for Phase 0 balance reads.
CV_SPEND_SECRET=

# --- Phase 1 additions (not used yet) ---
# DATABASE_URL=postgres://postgres:mysecretpassword@db:5432/conclave
# SIWE_SESSION_SECRET=change-me-to-a-long-random-string
# ADMIN_ADDRESSES=0xYourAdminAddressHere
