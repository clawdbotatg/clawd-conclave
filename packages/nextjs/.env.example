# Next.js frontend env. Copy to `.env.development` for local dev;
# set these in Vercel (or at build time for an IPFS build) for production.
#
# NEXT_PUBLIC_* vars are baked into the static bundle — for IPFS builds
# you must set them at `yarn ipfs` time, not at runtime.

# --- Wallet / RPC ---
# Alchemy API key. CLAUDE-global rule: never use public RPCs in production.
NEXT_PUBLIC_ALCHEMY_API_KEY=
# WalletConnect project ID from https://cloud.walletconnect.com
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=

# --- Conclave token (fork-configurable) ---
# Default is $CLAWD on Ethereum mainnet. Change these to fork the conclave
# for your own ERC-20.
NEXT_PUBLIC_TOKEN_ADDRESS=0x9f86dB9fc6f7c9408e8Fda3Ff8ce4e78ac7a6b07
NEXT_PUBLIC_TOKEN_SYMBOL=CLAWD
NEXT_PUBLIC_TOKEN_CHAIN_ID=1

# --- CV service (fork-configurable) ---
# Default: larv.ai. Point at your own CV service to run your own conclave.
NEXT_PUBLIC_CV_API_BASE_URL=https://larv.ai/api/cv

# --- Relay ---
# URL of the conclave relay server. Leave blank for Phase 0 (the landing page
# reads CV directly from the CV provider). Required from Phase 1 onward.
NEXT_PUBLIC_RELAY_URL=

# --- IPFS build flag (do not set manually; set by `yarn ipfs`) ---
# NEXT_PUBLIC_IPFS_BUILD=true
