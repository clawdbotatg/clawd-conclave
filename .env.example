# Root-level env for docker-compose. Copy to `.env` before `docker compose up`.
# Any value you leave blank falls back to a reasonable default.

# --- Database (local Postgres in docker) ---
POSTGRES_PASSWORD=conclave
POSTGRES_DB=conclave
POSTGRES_PORT=5432

# --- MediaMTX media server ---
MEDIAMTX_RTMP_PORT=1935
MEDIAMTX_HLS_PORT=8888
MEDIAMTX_WEBRTC_PORT=8889
MEDIAMTX_API_PORT=9997

# --- Relay ---
RELAY_PORT=4000
CORS_ORIGINS=*

# Default CV service is larv.ai. Point at your own CV backend if you're
# forking the conclave for your own token.
CV_API_BASE_URL=https://larv.ai/api/cv

# Required in Phase 1 when CV spending goes live. Get from the CV provider.
CV_SPEND_SECRET=

# Long random string. Used to sign SIWE session cookies in Phase 1.
# Generate with: openssl rand -hex 32
SIWE_SESSION_SECRET=

# Comma-separated addresses allowed to start/stop conclave sessions.
ADMIN_ADDRESSES=
