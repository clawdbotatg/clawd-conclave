# Root-level env for docker-compose. Copy to `.env` before `docker compose up`.
# Only needed if you're running the MediaMTX media server via docker
# (Phase 2) or if you're running the relay in a container.
#
# The default local dev flow uses SQLite + `yarn dev` — no docker required.

# --- MediaMTX media server (Phase 2) ---
MEDIAMTX_RTMP_PORT=1935
MEDIAMTX_HLS_PORT=8888
MEDIAMTX_WEBRTC_PORT=8889
MEDIAMTX_API_PORT=9997

# --- Relay (only if running via `docker compose --profile containerized up`) ---
RELAY_PORT=4000
CORS_ORIGINS=*

CV_API_BASE_URL=https://larv.ai/api/cv
# Required before /chat will work. Set this to the secret larv.ai issued you.
CV_SPEND_SECRET=
